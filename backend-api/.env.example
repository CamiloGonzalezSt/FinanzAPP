PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-a-strong-secret
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finanzas_app
# Un solo Client ID o varios (Web, iOS, Android) separados por coma / espacio
GOOGLE_CLIENT_ID=

# URL pública del backend (para links de reseteo en emails)
# En producción: https://tu-dominio.com
PUBLIC_URL=http://localhost:4000

# SMTP para envío de correos (recuperación de contraseña)
# Si no se configura, el link de reseteo se imprime solo en la consola del backend
# Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion
SMTP_FROM="Finanzas App" <tu_correo@gmail.com>
